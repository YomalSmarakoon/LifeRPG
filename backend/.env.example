# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
MONGODB_URI=mongodb://localhost:27017/liferpg

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── API ──────────────────────────────────────────────────────────────────────
API_PREFIX=api/v1

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Set to false in production
SWAGGER_ENABLED=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-real-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# ─── Refresh token ────────────────────────────────────────────────────────────
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=rt

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
# Cost factor 10–14. 12 is recommended for production.
BCRYPT_ROUNDS=12
