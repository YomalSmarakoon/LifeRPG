# ─────────────────────────────────────────────────────────────────────────────
# LifeRPG Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production        # Set in production

PORT=3001
API_PREFIX=api/v1

# ── Frontend (CORS) ───────────────────────────────────────────────────────────
# Development:
FRONTEND_URL=http://localhost:5173
# Production — no trailing slash, exact match:
# FRONTEND_URL=https://app.your-domain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev (replica set required for transactions):
MONGODB_URI=mongodb://localhost:27017/liferpg?replicaSet=rs0
# MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/liferpg?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# ── Refresh Token ─────────────────────────────────────────────────────────────
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=rt

# ── Security ──────────────────────────────────────────────────────────────────
# Min 10, max 14. 12 is a good balance of security and speed.
BCRYPT_ROUNDS=12

# ── Swagger ───────────────────────────────────────────────────────────────────
# true in development, false in production (Swagger UI never runs in production)
SWAGGER_ENABLED=true
# SWAGGER_ENABLED=false      # Set in production
